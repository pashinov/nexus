  "query": "\n            SELECT devices.id, devices.client_version, devices.last_seen_at\n            FROM devices\n            JOIN user_devices ON user_devices.device_id = devices.id\n            WHERE user_devices.user_id = $1\n            ORDER BY devices.last_seen_at DESC\n            ",
