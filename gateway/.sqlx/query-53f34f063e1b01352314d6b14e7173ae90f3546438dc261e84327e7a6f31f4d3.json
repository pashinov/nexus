  "query": "\n            SELECT devices.id, devices.uptime, devices.info, devices.created_at, devices.updated_at\n            FROM devices\n            JOIN user_devices ON user_devices.device_id = devices.id\n            WHERE user_devices.user_id = $1\n            ORDER BY devices.updated_at DESC\n            ",
